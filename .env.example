# .env.example — Copy this file to .env and fill in the values.
# NEVER commit .env to Git. Add .env to your .gitignore file.

# ---------------------------------------------------------------
# Required: 32-byte base64-encoded AES-256 master key.
# Generate with:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ---------------------------------------------------------------
ENCRYPTION_KEY=REPLACE_ME

# ---------------------------------------------------------------
# Required: Random secret for signing session cookies.
# Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------
SECRET_KEY=REPLACE_ME

# ---------------------------------------------------------------
# Optional: GitHub OAuth credentials.
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:5000/oauth/github/callback
# ---------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------
# Optional: Use PostgreSQL instead of SQLite in production.
# ---------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/secure_auth_db
